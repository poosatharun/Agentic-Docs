# Environment variables for the Agentic Docs UI
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is git-ignored — never commit real values.

# Optional: Override the backend base URL.
# Leave empty (default) to use the Vite dev-server proxy, which forwards
# /agentic-docs/api/* requests to http://localhost:8080 automatically.
# Set this when deploying the UI to a different origin than the Spring Boot app.
#
# Example: VITE_API_BASE_URL=https://api.mycompany.com
VITE_API_BASE_URL=
